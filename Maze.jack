class Maze {
    field Array cells;
    field int rows;
    field int cols;

    constructor Maze new() {
        let rows = 16;
        let cols = 32;
        let cells = Array.new(512);
        return this;
    } //Constructor del laberinto

    method int getCell(int row, int col) {
        return cells[(row * cols) + col];
    } //Obtener el valor de la celda 16x16 (0 para camino, 1 para muro y 2 para la salida)

    method void setCell(int row, int col, int value) {
        let cells[(row * cols) + col] = value;
        return;
    } //"Setear" o asignar valores del laberinto

    method boolean canMove(int row, int col) {
        var int val;
        let val = getCell(row, col);
        return ~(val = 1);
    } //Funcion que permite el movimiento del jugador

