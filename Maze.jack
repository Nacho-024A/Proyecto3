    //Metodo de dibujo en pantalla
    method void draw() {
        var int r, c, val, x, y;
        let r = 0;
        while (r < rows) { //Ciclo de recorrido de celdas por celdas simuladas en un array 
            let c = 0;
            while (c < cols) {
                let val = getCell(r, c);
                let x = c * 16;
                let y = r * 16;
                if (val = 1) {
                    //Dibujar el rectangulo en la celda de 16x16
                    do Screen.setColor(true);
                    do Screen.drawRectangle(x, y, x + 15, y + 15);
                }
                if (val = 0) {
                    do Screen.setColor(false);
                    do Screen.drawRectangle(x, y, x + 15, y + 15);
                    //Bordeado Negro
                    do Screen.setColor(true);
                    do Screen.drawLine(x, y, x + 15, y);          // Arriba
                    do Screen.drawLine(x, y + 15, x + 15, y + 15); // Abajo
                    do Screen.drawLine(x, y, x, y + 15);           // Izquierda
                    do Screen.drawLine(x + 15, y, x + 15, y + 15); // Derecha
                }
                if (val = 2) {
                    //Se dibuja un rectangulo pequeño en pantalla
                    do Screen.setColor(false);
                    do Screen.drawRectangle(x, y, x + 15, y + 15);
                    do Screen.setColor(true);
                    do Screen.drawRectangle(x + 4, y + 4, x + 11, y + 11);
                }
                let c = c + 1;
            }
            let r = r + 1;
        }
        return;
    }

    //Metodo de recolector de basura
    method void dispose() {
        do cells.dispose();
        do Memory.deAlloc(this);
        return;
    }
